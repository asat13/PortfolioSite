@page "/projects"
@attribute [StreamRendering]
@rendermode InteractiveServer
@using PortfolioWebsiteProject.Models
@using System.Linq

<PageTitle>Projects</PageTitle>

<h1>Projects</h1>

<p>This component demonstrates showing data.</p>


<div class="filters">
    <label>Filter by name:</label>
    <input placeholder="Type project name..." value="@nameFilter" @oninput="OnNameInput" />

    <label>Technologies (multi-select):</label>
    <div class="checkbox-list">
        @foreach (var tech in AllTechs)
        {
            <label>
                <input type="checkbox" checked="@selectedTechs.Contains(tech)" @onchange="e => HandleTechChange(tech, (bool)e.Value)" />
                @tech
            </label>
        }
    </div>

    <label>Type (multi-select):</label>
    <div class="checkbox-list">
        @foreach (var t in AllTypes)
        {
            <label>
                <input type="checkbox" checked="@selectedTypes.Contains(t)" @onchange="e => HandleTypeChange(t, (bool)e.Value)" />
                @t
            </label>
        }
    </div>

    <button class="btn btn-secondary" @onclick="ClearFilters">Clear</button>
</div>

@if (projects == null)
{
    <p><em>Loading...</em></p>
}
else
{
    var filtered = FilteredProjects().ToArray();
    if (filtered.Length == 0)
    {
        <p><em>No projects match the current filters.</em></p>
    }
    else
    {
        @foreach (var project in filtered)
        {
            <ProjectView Project="project" />
        }
    }
}

@code {
    private Project[]? projects = new[] {
        new Project
        {
            Title = "Space Shooter",
            Description = "A Unity-based 2D shooter.",
            ImageSrc = "images/error.svg",
            ButtonText = "Play",
            ButtonUrl = "https://example.com/space-shooter",
            Techs = new[] { "Unity", "C#" },
            Type = "Game"
        },
        new Project
        {
            Title = "Portfolio Site",
            Description = "This website built with Blazor.",
            ImageSrc = "images/error.svg",
            ButtonText = "Source",
            ButtonUrl = "https://example.com/portfolio",
            Techs = new[] { ".NET", "Blazor", "C#" },
            Type = "Web"
        }
    };

    private string nameFilter = string.Empty;
    private HashSet<string> selectedTechs = new();
    private HashSet<string> selectedTypes = new();

    private IEnumerable<string> AllTechs => projects?.SelectMany(p => p.Techs ?? Array.Empty<string>()).Distinct().OrderBy(x => x) ?? Enumerable.Empty<string>();
    private IEnumerable<string> AllTypes => projects?.Select(p => p.Type).Where(x => !string.IsNullOrEmpty(x)).Distinct().OrderBy(x => x) ?? Enumerable.Empty<string>();

    private IEnumerable<Project> FilteredProjects()
    {
        if (projects == null) yield break;

        foreach (var p in projects)
        {
            if (!string.IsNullOrWhiteSpace(nameFilter))
            {
                if (!p.Title.Contains(nameFilter, StringComparison.OrdinalIgnoreCase))
                    continue;
            }

            if (selectedTechs.Count > 0)
            {
                var techs = p.Techs ?? Array.Empty<string>();
                if (!techs.Any(t => selectedTechs.Contains(t)))
                    continue;
            }

            if (selectedTypes.Count > 0)
            {
                if (!selectedTypes.Contains(p.Type))
                    continue;
            }

            yield return p;
        }
    }

    private void ClearFilters()
    {
        nameFilter = string.Empty;
        selectedTechs.Clear();
        selectedTypes.Clear();
    }

    private void HandleTechChange(string tech, bool isChecked)
    {
        if (isChecked) selectedTechs.Add(tech); else selectedTechs.Remove(tech);
        StateHasChanged();
    }

    private void HandleTypeChange(string t, bool isChecked)
    {
        if (isChecked) selectedTypes.Add(t); else selectedTypes.Remove(t);
        StateHasChanged();
    }

    private void OnNameInput(ChangeEventArgs e)
    {
        nameFilter = e.Value?.ToString() ?? string.Empty;
    }

}
