@page "/projects"
@attribute [StreamRendering]
@rendermode InteractiveServer
@using PortfolioWebsiteProject.Models
@using System.Linq
@using System.Text.Json
@using System.IO

<PageTitle>Projects — Andre Maestas</PageTitle>

<div class="projects-page">
    <div class="section-container">
        <div class="projects-header">
            <h1 class="section-heading">My Work</h1>
            <p class="projects-intro">A collection of games, apps, and web projects I've built across game development, desktop, and web platforms.</p>
        </div>

        <div class="filters">
            <div class="filter-group">
                <label class="filter-label">Search</label>
                <input class="filter-search" placeholder="Type project name..." value="@nameFilter" @oninput="OnNameInput" />
            </div>

            <div class="filter-group">
                <label class="filter-label">Technologies</label>
                <div class="pill-list">
                    @foreach (var tech in AllTechs)
                    {
                        <button class="pill @(selectedTechs.Contains(tech) ? "pill--active" : "")"
                                @onclick="() => ToggleTech(tech)">
                            @tech
                        </button>
                    }
                </div>
            </div>

            <div class="filter-group">
                <label class="filter-label">Type</label>
                <div class="pill-list">
                    @foreach (var t in AllTypes)
                    {
                        <button class="pill @(selectedTypes.Contains(t) ? "pill--active" : "")"
                                @onclick="() => ToggleType(t)">
                            @t
                        </button>
                    }
                </div>
            </div>

            <button class="btn-clear" @onclick="ClearFilters">Clear filters</button>
        </div>

        @if (projects == null)
        {
            <p class="projects-empty"><em>Loading...</em></p>
        }
        else
        {
            var filtered = FilteredProjects().ToArray();
            if (filtered.Length == 0)
            {
                <p class="projects-empty"><em>No projects match the current filters.</em></p>
            }
            else
            {
                <div class="project-grid">
                    @foreach (var project in filtered)
                    {
                        <ProjectView Project="project" />
                    }
                </div>
            }
        }
    </div>
</div>

@code {
    private Project[]? projects;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            string filePath = Path.Combine(AppContext.BaseDirectory, "Data", "projects.json");
            if (File.Exists(filePath))
            {
                string json = await File.ReadAllTextAsync(filePath);
                var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                projects = JsonSerializer.Deserialize<Project[]>(json, options);
            }
            else
            {
                projects = Array.Empty<Project>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading projects: {ex.Message}");
            projects = Array.Empty<Project>();
        }
    }

    private string nameFilter = string.Empty;
    private HashSet<string> selectedTechs = new();
    private HashSet<string> selectedTypes = new();

    private IEnumerable<string> AllTechs => projects?.SelectMany(p => p.Techs ?? Array.Empty<string>()).Distinct().OrderBy(x => x) ?? Enumerable.Empty<string>();
    private IEnumerable<string> AllTypes => projects?.Select(p => p.Type).Where(x => !string.IsNullOrEmpty(x)).Distinct().OrderBy(x => x) ?? Enumerable.Empty<string>();

    private IEnumerable<Project> FilteredProjects()
    {
        if (projects == null) yield break;

        foreach (var p in projects)
        {
            if (!string.IsNullOrWhiteSpace(nameFilter))
            {
                if (!p.Title.Contains(nameFilter, StringComparison.OrdinalIgnoreCase))
                    continue;
            }

            if (selectedTechs.Count > 0)
            {
                var techs = p.Techs ?? Array.Empty<string>();
                if (techs.Where(t => selectedTechs.Contains(t)).Count() < selectedTechs.Count)
                    continue;
            }

            if (selectedTypes.Count > 0)
            {
                if (!selectedTypes.Contains(p.Type))
                    continue;
            }

            yield return p;
        }
    }

    private void ClearFilters()
    {
        nameFilter = string.Empty;
        selectedTechs.Clear();
        selectedTypes.Clear();
    }

    private void ToggleTech(string tech)
    {
        if (!selectedTechs.Remove(tech)) selectedTechs.Add(tech);
        StateHasChanged();
    }

    private void ToggleType(string t)
    {
        if (!selectedTypes.Remove(t)) selectedTypes.Add(t);
        StateHasChanged();
    }

    private void OnNameInput(ChangeEventArgs e)
    {
        nameFilter = e.Value?.ToString() ?? string.Empty;
    }
}
