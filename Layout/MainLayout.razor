@inherits LayoutComponentBase

<a class="skip-link" href="#main-content">Skip to main content</a>

<header class="site-header" role="banner">
    <div class="header-inner">
        <a class="logo" href="/">Andre Maestas</a>
        <NavMenu />
    </div>
</header>

<main class="site-main" id="main-content">
    @Body
</main>

<footer class="site-footer">
    <div class="footer-inner">
        <span class="footer-copy">&copy; Andre Maestas 2026</span>
        <div class="footer-links">
            <a class="footer-link" href="https://github.com/asat13" target="_blank" rel="noopener noreferrer">GitHub</a>
            <a class="footer-link" href="https://www.linkedin.com/in/andremaestas/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </div>
    </div>
</footer>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">&#x1F5D9;</a>
</div>
