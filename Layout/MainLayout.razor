@inherits LayoutComponentBase

<a class="skip-link" href="#main-content">Skip to main content</a>

<header class="site-header" role="banner">
    <div class="header-inner">
        <div class="logo-group">
            <a class="logo" href="/">Andre Maestas</a>
            <img class="logo-img" src="images/Home/AMLogo.png" alt="Logo icon" aria-hidden="true" />
        </div>
        <NavMenu />
    </div>
</header>

<main class="site-main" id="main-content">
    <ErrorBoundary @ref="errorBoundary">
        <ChildContent>
            @Body
        </ChildContent>
        <ErrorContent>
            <section class="error-page">
                <h1 class="error-heading">Something went wrong</h1>
                <p class="error-message">An unexpected error occurred while loading this page.</p>
                <div class="error-actions">
                    <button class="btn-primary-cta" @onclick="Recover">Try Again</button>
                    <a class="error-home-link" href="/">Go Home</a>
                </div>
            </section>
        </ErrorContent>
    </ErrorBoundary>
</main>

<footer class="site-footer">
    <div class="footer-inner">
        <span class="footer-copy">&copy; Andre Maestas 2026</span>
        <div class="footer-links">
            <a class="footer-link" href="https://github.com/asat13" target="_blank" rel="noopener noreferrer">GitHub</a>
            <a class="footer-link" href="https://www.linkedin.com/in/andremaestas/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </div>
    </div>
</footer>

@code {
    private ErrorBoundary? errorBoundary;

    private void Recover()
    {
        errorBoundary?.Recover();
    }
}
