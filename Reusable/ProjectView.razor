@namespace PortfolioSiteWasm.Reusable
@using Microsoft.AspNetCore.Components
@using PortfolioSiteWasm.Models

<div class="project-card">
    <div class="pv-image-wrapper">
        <img src="@Project?.ImageSrc" alt="@Project?.Title" class="pv-image" loading="lazy" />
        @if (!string.IsNullOrEmpty(Project?.ProjectCategory))
        {
            <span class="pv-category-badge @(Project.ProjectCategory == "Professional" ? "pv-category-badge--pro" : "pv-category-badge--personal")">
                @Project.ProjectCategory
            </span>
        }
    </div>

    <div class="pv-label-bar">
        <h3 class="pv-title">@Project?.Title</h3>
    </div>

    <div class="pv-body">
        <p class="pv-description">@Project?.Description</p>
        @if (!string.IsNullOrEmpty(Project?.Contribution))
        {
            <p class="pv-contribution">@Project.Contribution</p>
        }
        @if (Project?.Techs?.Any() == true)
        {
            <div class="pv-techs">
                @foreach (var tech in Project.Techs)
                {
                    <span class="pv-tech-badge">@tech</span>
                }
            </div>
            <div class="pv-meta">
                <span class="pv-description">@Project?.Year</span>
                <span class="pv-description">-</span>
                <span class="pv-description">@Project?.Type</span>
            </div>
        }
    </div>

    <div class="pv-cta">
        <a class="pv-button" href="/project/@Uri.EscapeDataString(Project?.Title ?? string.Empty)">
            View Project
        </a>
    </div>
</div>

@code {
    [Parameter]
    public Project? Project { get; set; }
}
